#!/bin/bash

# Check if CFILE is set
if [ -z "$CFILE" ]; then
  echo "CFILE variable is not set"
  exit 1
fi

# Check if the file exists
if [ ! -f "$CFILE" ]; then
  echo "File $CFILE does not exist"
  exit 1
fi

# Create output file name by replacing .c with .s
outfile="${CFILE%.c}.s"

# Generate assembly code
gcc -S "$CFILE" -o "$outfile"
